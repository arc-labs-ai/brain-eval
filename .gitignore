# Rust build artifacts
/target
**/*.rs.bk
*.pdb

# Cargo lockfile — this crate ships a binary (the `brain-eval` CLI), so
# committing Cargo.lock is the right call. Override here only if
# upstream pinning becomes painful.
# /Cargo.lock

# Local-development dependency override — redirects the brain-db git
# deps to a local checkout. Per-machine; never committed. Copy from
# .cargo/config.toml.example to enable.
/.cargo/config.toml

# IDE / editor noise
.idea/
.vscode/
*.swp
*.swo
*~

# OS noise
.DS_Store
Thumbs.db

# Eval-side outputs
/eval-reports/
/target/eval-reports/
/.brain-eval-datasets/
# Downloaded benchmark datasets (fetched by scripts/fetch-datasets.sh).
/datasets/
*.log

# Local scratch
/scratch/
# Machine-specific scratch analysis script at the repo root.
/analyze_reads.py
# Incremental per-run JSONL sidecars (also covered by /target/eval-reports/).
/target/eval-reports/*.jsonl
